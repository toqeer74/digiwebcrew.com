  slug: string;
  description: string;
  icon: string;
  color: string;
  categories: ServiceCategory[];
};

export type TechLab = {
  title: string;
  slug: string;
  description: string;
  iconName: string;
  capabilities: string[];
  relatedServices: string[];
};

